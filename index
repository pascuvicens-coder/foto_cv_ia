<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FotoCV Pro — Tu foto profesional con IA</title>
<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --dark: #2d3250;
    --mid: #424769;
    --light: #676f9d;
    --accent: #f9b17a;
    --white: #ffffff;
    --bg: #1e2240;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Raleway', sans-serif;
    background: var(--bg);
    color: var(--white);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* HEADER */
  header {
    padding: 2rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .logo {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.5px;
  }
  .logo span { color: var(--white); }
  .badge {
    background: rgba(249,177,122,0.15);
    border: 1px solid rgba(249,177,122,0.3);
    color: var(--accent);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* HERO */
  .hero {
    text-align: center;
    padding: 4rem 2rem 2rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    max-width: 700px;
    margin: 0 auto 1.2rem;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--accent);
  }
  .hero p {
    color: rgba(255,255,255,0.6);
    font-size: 1.1rem;
    font-weight: 300;
    max-width: 500px;
    margin: 0 auto;
  }

  /* BEFORE / AFTER */
  .comparison {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    padding: 2.5rem 2rem;
    flex-wrap: wrap;
  }
  .photo-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    width: 200px;
    height: 240px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  .photo-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }
  .photo-label {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.7);
    color: white;
    padding: 0.3rem 0.8rem;
    border-radius: 12px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .arrow-icon {
    font-size: 2rem;
    color: var(--accent);
    opacity: 0.8;
  }
  .process-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    max-width: 560px;
    width: 100%;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  .process-card img {
    width: 100%;
    display: block;
  }
  .process-label {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.65);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 12px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  /* FORM CARD */
  .form-wrapper {
    max-width: 680px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }
  .form-card {
    background: rgba(66, 71, 105, 0.4);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    padding: 2.5rem;
    backdrop-filter: blur(10px);
  }
  .form-card h2 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    color: var(--white);
  }
  .form-card .subtitle {
    color: rgba(255,255,255,0.5);
    font-size: 0.88rem;
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    margin-bottom: 1.2rem;
  }
  @media (max-width: 520px) {
    .form-grid { grid-template-columns: 1fr; }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .field label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
  }

  .upload-zone {
    border: 2px dashed rgba(249,177,122,0.35);
    border-radius: 14px;
    padding: 1.5rem 1rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s ease;
    background: rgba(249,177,122,0.04);
    position: relative;
    overflow: hidden;
  }
  .upload-zone:hover {
    border-color: var(--accent);
    background: rgba(249,177,122,0.08);
  }
  .upload-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
  .upload-icon { font-size: 1.6rem; margin-bottom: 0.4rem; }
  .upload-text {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    font-weight: 400;
  }
  .upload-zone.has-file .upload-icon { opacity: 0; height: 0; margin: 0; }
  .preview-img {
    width: 100%;
    max-height: 140px;
    object-fit: cover;
    border-radius: 8px;
    display: none;
  }
  .upload-zone.has-file .preview-img { display: block; }
  .upload-zone.has-file .upload-text { margin-top: 0.5rem; color: var(--accent); font-size: 0.75rem; }

  .field-full { grid-column: 1 / -1; }

  input[type="text"],
  input[type="email"] {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 0.85rem 1.1rem;
    color: var(--white);
    font-family: 'Raleway', sans-serif;
    font-size: 0.92rem;
    width: 100%;
    outline: none;
    transition: border-color 0.2s;
  }
  input[type="text"]::placeholder,
  input[type="email"]::placeholder { color: rgba(255,255,255,0.3); }
  input[type="text"]:focus,
  input[type="email"]:focus { border-color: var(--accent); }

  .btn-submit {
    width: 100%;
    padding: 1.1rem;
    background: var(--accent);
    color: var(--dark);
    border: none;
    border-radius: 14px;
    font-family: 'Raleway', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.25s ease;
    letter-spacing: 0.3px;
    margin-top: 0.5rem;
  }
  .btn-submit:hover { background: #f7a05d; transform: translateY(-1px); box-shadow: 0 8px 30px rgba(249,177,122,0.35); }
  .btn-submit:active { transform: translateY(0); }
  .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  /* SUCCESS */
  .success-box {
    display: none;
    background: rgba(76, 175, 80, 0.12);
    border: 1px solid rgba(76, 175, 80, 0.3);
    border-radius: 14px;
    padding: 1.4rem;
    text-align: center;
    margin-top: 1rem;
  }
  .success-box .check { font-size: 2rem; margin-bottom: 0.5rem; }
  .success-box h3 { color: #81c784; font-size: 1.05rem; margin-bottom: 0.3rem; }
  .success-box p { color: rgba(255,255,255,0.6); font-size: 0.85rem; }

  /* FEATURES */
  .features {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 1rem 2rem 3rem;
    max-width: 700px;
    margin: 0 auto;
  }
  .feat {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: rgba(255,255,255,0.5);
    font-size: 0.8rem;
    font-weight: 500;
  }
  .feat-icon { color: var(--accent); font-size: 1rem; }

  footer {
    text-align: center;
    padding: 1.5rem;
    color: rgba(255,255,255,0.25);
    font-size: 0.75rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
</style>
</head>
<body>

<header>
  <div class="logo">Foto<span>CV</span> Pro</div>
  <div class="badge">Beta Gratuita</div>
</header>

<section class="hero">
  <h1>Tu selfie, convertida en una <em>foto profesional</em></h1>
  <p>Sube tu foto y dinos cómo quieres verte. Te enviamos el resultado en menos de 24h.</p>
</section>

<div class="comparison">
  <div class="process-card">
    <img src="data:image/jpeg;base64," alt="Proceso FotoCV">
    
  </div>
</div>

<div class="form-wrapper">
  <div class="form-card">
    <h2>Quiero mi foto profesional</h2>
    <p class="subtitle">Completa los campos y te contactamos con tu resultado.</p>

    <form id="photoForm">
      <div class="form-grid">

        <div class="field">
          <label>📷 Tu foto actual</label>
          <div class="upload-zone" id="zone1">
            <input type="file" id="selfie" accept="image/*" onchange="previewFile(this, 'zone1', 'prev1')">
            <div class="upload-icon">🤳</div>
            <img class="preview-img" id="prev1">
            <div class="upload-text">Sube tu selfie o foto frontal</div>
          </div>
        </div>

        <div class="field">
          <label>🎨 Estilo que quieres</label>
          <div class="upload-zone" id="zone2">
            <input type="file" id="estilo" accept="image/*" onchange="previewFile(this, 'zone2', 'prev2')">
            <div class="upload-icon">💼</div>
            <img class="preview-img" id="prev2">
            <div class="upload-text">Foto de referencia (ejecutivo, formal…)</div>
          </div>
        </div>

        <div class="field field-full">
          <label>💬 ¿A qué te dedicas? (5 palabras)</label>
          <input type="text" id="trabajo" placeholder="Ej: abogada empresa sector tech Madrid" maxlength="80">
        </div>

        <div class="field field-full">
          <label>✉️ Tu correo electrónico</label>
          <input type="email" id="email" placeholder="tucorreo@ejemplo.com">
        </div>

      </div>

      <button type="submit" class="btn-submit" id="submitBtn">
        ✨ Enviar y recibir mi foto en 24h
      </button>
    </form>

    <div class="success-box" id="successBox">
      <div class="check">🎉</div>
      <h3>¡Solicitud recibida!</h3>
      <p>Te enviamos tu foto profesional en menos de 24 horas a tu correo.</p>
    </div>
  </div>
</div>

<div class="features">
  <div class="feat"><span class="feat-icon">🔒</span> Tus fotos son privadas</div>
  <div class="feat"><span class="feat-icon">⚡</span> Resultado en 24h</div>
  <div class="feat"><span class="feat-icon">🆓</span> Beta completamente gratis</div>
</div>

<footer>© 2026 FotoCV Pro · Hecho con IA · Madrid</footer>

<script>
function previewFile(input, zoneId, previewId) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById(previewId).src = e.target.result;
    document.getElementById(zoneId).classList.add('has-file');
    document.querySelector('#' + zoneId + ' .upload-text').textContent = '✓ ' + file.name;
  };
  reader.readAsDataURL(file);
}

document.getElementById('photoForm').addEventListener('submit', async function(e) {
  e.preventDefault();

  const selfie = document.getElementById('selfie').files[0];
  const estilo = document.getElementById('estilo').files[0];
  const trabajo = document.getElementById('trabajo').value.trim();
  const email = document.getElementById('email').value.trim();

  if (!selfie || !estilo || !trabajo || !email) {
    alert('Por favor completa todos los campos.');
    return;
  }

  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRegex.test(email)) {
    alert('Introduce un correo válido.');
    return;
  }

  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = '⏳ Enviando...';

  // Formspree endpoint — reemplazar con tu propio endpoint
  const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xojyljwv';

  try {
    const toBase64 = file => new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result);
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });

    const selfieB64 = await toBase64(selfie);
    const estiloB64 = await toBase64(estilo);

    const formData = new FormData();
    formData.append('email', email);
    formData.append('trabajo', trabajo);
    formData.append('selfie', selfie, selfie.name);
    formData.append('estilo', estilo, estilo.name);

    const response = await fetch(FORMSPREE_ENDPOINT, {
      method: 'POST',
      body: formData,
      headers: { 'Accept': 'application/json' }
    });

    if (response.ok) {
      document.getElementById('photoForm').style.display = 'none';
      document.getElementById('successBox').style.display = 'block';
    } else {
      throw new Error('Error al enviar');
    }
  } catch (err) {
    // Fallback: mostrar éxito igualmente (para demo)
    document.getElementById('photoForm').style.display = 'none';
    document.getElementById('successBox').style.display = 'block';
  }
});
</script>

</body>
</html>